# ========================================
# 性能优化配置示例
# ========================================
# 复制此文件为 .env.production 并在生产环境使用

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APPLICATION
#--------------------------------------------------------------------
app.baseURL = "https://yourdomain.com/"
app.indexPage = ""
app.uriProtocol = "REQUEST_URI"
app.defaultLocale = "zh-CN"
app.negotiateLocale = false
app.CSPEnabled = true

# CDN配置（生产环境启用）
app.cdnUrl = "https://cdn.yourdomain.com"
app.assetVersion = "20240101"

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = "localhost"
database.default.database = "codeigniter_blog"
database.default.username = "your_db_user"
database.default.password = "your_strong_password"
database.default.DBDriver = "MySQLi"
database.default.DBPrefix = ""
database.default.port = 3306

#--------------------------------------------------------------------
# CACHE - 推荐使用Redis
#--------------------------------------------------------------------
cache.store = "redis"
cache.validators = false

# Redis配置
cache.redis.host = "127.0.0.1"
cache.redis.password = "your_redis_password"
cache.redis.port = 6379
cache.redis.database = 0
cache.redis.timeout = 0
cache.redis.prefix = "blog_"

#--------------------------------------------------------------------
# SESSION - 推荐使用Redis存储会话
#--------------------------------------------------------------------
session.driver = "CodeIgniter\Session\Handlers\RedisHandler"
session.cookieName = "ci_session"
session.expiration = 7200
session.savePath = "tcp://127.0.0.1:6379?auth=your_redis_password&database=1"
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 3  # 生产环境只记录error及以上
logger.handlers = "file"
logger.logFile = "php://stdout"
logger.filePermissions = 0644
logger.dateFormat = "Y-m-d H:i:s"

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# 务必生成加密密钥: php spark key:generate
encryption.key = "base64:YOUR_GENERATED_KEY_HERE="
encryption.driver = "OpenSSL"

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
security.csrfProtection = "cookie"
security.tokenRandomize = true
security.headerXSSProtection = "1; mode=block"
security.headerContentTypeNosniff = "nosniff"
security.headerXFrameOptions = "SAMEORIGIN"
security.cspReportOnly = false

#--------------------------------------------------------------------
# EMAIL (可选)
#--------------------------------------------------------------------
email.fromEmail = "noreply@yourdomain.com"
email.fromName = "Your Blog"
email.protocol = "smtp"
email.SMTPHost = "smtp.yourdomain.com"
email.SMTPUser = "your_email@yourdomain.com"
email.SMTPPass = "your_email_password"
email.SMTPPort = 587
email.SMTPCrypto = "tls"
