#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APPLICATION
#--------------------------------------------------------------------
app.baseURL = "http://testboke.com/"
app.indexPage = ""
app.uriProtocol = "REQUEST_URI"
app.defaultLocale = "zh-CN"
app.negotiateLocale = false
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = "localhost"
database.default.database = "codeigniter_blog"
database.default.username = "root"
database.default.password = "root"
database.default.DBDriver = "MySQLi"
database.default.DBPrefix = ""
database.default.port = 3306

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------
email.default.fromEmail = ""
email.default.fromName = ""

#--------------------------------------------------------------------
# CACHE
#--------------------------------------------------------------------
cache.store = "file"
cache.validators = false

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver = "CodeIgniter\Session\Handlers\FileHandler"
session.cookieName = "ci_session"
session.expiration = 7200
# session.savePath = "writable/session"  # 注释掉，使用Session.php中的默认配置
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 4
logger.handlers = "file"
logger.logFile = "php://stdout"
logger.filePermissions = 0644
logger.dateFormat = "Y-m-d H:i:s"

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
encryption.key = ""
encryption.driver = "OpenSSL"

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
security.csrfProtection = cookie
security.tokenRandomize = false
security.headerXSSProtection = "1; mode=block"
security.headerContentTypeNosniff = "nosniff"
security.headerXFrameOptions = "SAMEORIGIN"
security.cspReportOnly = false
