# ======================================
# CI4 框架 官方标准忽略文件
# ======================================

#  writable 缓存/日志/会话（绝对不上传）
writable/cache/*
writable/logs/*
writable/debug/*
writable/session/*
!writable/cache/index.html
!writable/logs/index.html
!writable/debug/index.html
!writable/session/index.html

# 上传文件（根据你的需求）
# writable/uploads/*

# 环境配置（不能上传！）
env
.env

# Composer 依赖
vendor/

# PHPUnit 测试缓存
build/
coverage/
.phpunit.result.cache

# 系统/编辑器垃圾文件
.DS_Store
.idea/
.vscode/
*.swp
*.bak
*.tmp
node_modules/
npm-debug.log